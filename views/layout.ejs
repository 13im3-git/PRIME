<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'DeviceCompare' %></ title>
  <meta name="description" content="Compare phones, laptops, power stations, tablets, wearables and more. Find the best device for your needs.">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="logo">
        <span class="logo-icon">◆</span>
        <span class="logo-text">Prime Comparison</span>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="nav-link active">Home</a></li>
        <li><a href="/compare" class="nav-link">Compare</a></li>
        <li><a href="/products" class="nav-link">Categories</a></li>
        <li><a href="/products" class="nav-link">Brands</a></li>
        <li><a href="/products?sort=newest" class="nav-link">Latest</a></li>
      </ul>
      <div class="nav-actions">
        <div class="search-box">
          <input type="text" id="navSearch" placeholder="Search devices..." autocomplete="off">
          <button id="navSearchBtn">⌕</button>
          <div class="search-dropdown" id="searchDropdown"></div>
        </div>
        <div class="theme-toggle" id="themeToggle">
          <div class="theme-toggle-option active" data-mode="light">L</div>
          <div class="theme-toggle-option" data-mode="dark">D</div>
        </div>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <%- body %>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
    <div>
      <h4>Prime Comparison</h4>
      <p>Luxury-level device comparison for modern buyers. Compare smartphones, laptops, tablets, power stations, wearables and more.</p>
    </div>
        <div>
          <h4>Categories</h4>
          <ul>
            <% categories.forEach(c => { %>
              <li><a href="/category/<%= encodeURIComponent(c) %>"><%= c %></a></li>
            <% }) %>
          </ul>
        </div>
    <div>
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/products">Browse All</a></li>
        <li><a href="/compare">Compare Devices</a></li>
        <li><a href="/products?category=Laptops">Laptops</a></li>
        <li><a href="/products?category=Power+Stations">Power Stations</a></li>
      </ul>
    </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2024 DeviceCompare. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>